[Unit]
Description=AutoTRD Daily Trading Run
After=network.target opend.service

[Service]
Type=oneshot
User=trader
WorkingDirectory=/home/trader/autoTRD
ExecStart=/home/trader/autoTRD/.venv/bin/python -m src.main
Environment=PYTHONPATH=/home/trader/autoTRD
EnvironmentFile=/home/trader/autoTRD/.env
