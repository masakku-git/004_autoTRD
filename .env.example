# Broker (moomoo OpenD)
MOOMOO_HOST=127.0.0.1
MOOMOO_PORT=11111
MOOMOO_TRADE_PASSWORD_MD5=
MOOMOO_TRADE_ENV=SIMULATE
# acc_id: 0 = 先頭口座。明示指定する場合は scripts/check_acc_list.py の結果から取得して設定
MOOMOO_ACC_ID=0
# JP口座区分: JP_GENERAL=一般 / JP_TOKUTEI=特定 / JP_NISA_GENERAL=一般NISA 等
MOOMOO_JP_ACC_TYPE=JP_TOKUTEI

# Trading
DRY_RUN=true
MAX_POSITIONS=3
RISK_PER_TRADE_PCT=0.02
MAX_PORTFOLIO_EXPOSURE_PCT=0.90
DAILY_LOSS_LIMIT_PCT=0.03

# Database (PostgreSQL)
DATABASE_URL=postgresql://autotrd:password@localhost:5432/autotrd

# Notification (Slack Incoming Webhook)
SLACK_WEBHOOK_URL=

# Timezone
TZ=Asia/Tokyo
