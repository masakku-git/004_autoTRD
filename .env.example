# Broker (moomoo OpenD)
MOOMOO_HOST=127.0.0.1
MOOMOO_PORT=11111
MOOMOO_TRADE_PASSWORD_MD5=
MOOMOO_TRADE_ENV=SIMULATE

# Trading
DRY_RUN=true
MAX_POSITIONS=3
RISK_PER_TRADE_PCT=0.02
MAX_PORTFOLIO_EXPOSURE_PCT=0.90
DAILY_LOSS_LIMIT_PCT=0.03

# Database (PostgreSQL)
DATABASE_URL=postgresql://autotrd:password@localhost:5432/autotrd

# Notification (LINE Notify)
LINE_NOTIFY_TOKEN=

# Timezone
TZ=Asia/Tokyo
